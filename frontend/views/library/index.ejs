<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library - ARUS</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .book-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            gap: 20px;
            margin-top: 24px;
        }
        .book-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 22px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .book-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }
        .book-icon {
            width: 52px;
            height: 52px;
            border-radius: 12px;
            background: linear-gradient(135deg, #1e3a8a, #3b82f6);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: white;
            margin-bottom: 4px;
        }
        .book-title {
            font-weight: 700;
            font-size: 1rem;
            color: #1e293b;
            line-height: 1.3;
        }
        .book-author {
            font-size: 0.85rem;
            color: #64748b;
        }
        .book-cat {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 999px;
            font-size: 0.72rem;
            font-weight: 600;
            background: #eff6ff;
            color: #1e40af;
        }
        .book-copies {
            font-size: 0.82rem;
            font-weight: 600;
        }
        .copies-ok { color: #10b981; }
        .copies-none { color: #ef4444; }
        .search-bar {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
            margin-bottom: 0;
        }
        .search-bar input, .search-bar select {
            padding: 9px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            font-size: 0.9rem;
            background: white;
            color: #334155;
        }
        .search-bar input { flex: 1; min-width: 200px; }
    </style>
    <script src="/js/theme.js"></script>
</head>

<body>
    <div class="dashboard-container">
        <%- include('../partials/header') %>

        <!-- Page Header -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
            <div>
                <h1 style="margin-bottom:4px;"><i class="fas fa-book-open" style="color:#3b82f6; margin-right:10px;"></i>Library</h1>
                <p style="margin:0; color:#64748b;">Browse and borrow books from our library collection.</p>
            </div>
            <% if(isLibrarianOrAdmin) { %>
                <a href="/library/manage" class="btn btn-primary"><i class="fas fa-cog"></i> Manage Library</a>
            <% } %>
        </div>

        <%- include('../partials/messages') %>

        <!-- Search + Filter -->
        <div class="glass-card" style="padding:16px 20px; margin-bottom:8px;">
            <form method="GET" action="/library" class="search-bar">
                <input type="text" name="search" placeholder="Search by title, author or ISBN..." value="<%= search %>">
                <select name="category">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat %>" <%= selectedCategory === cat ? 'selected' : '' %>><%= cat %></option>
                    <% }) %>
                </select>
                <button type="submit" class="btn btn-primary" style="padding:9px 18px;"><i class="fas fa-search"></i> Search</button>
                <% if(search || selectedCategory) { %>
                    <a href="/library" class="btn btn-secondary" style="padding:9px 18px;">Clear</a>
                <% } %>
            </form>
        </div>

        <!-- Results count -->
        <p style="color:#64748b; font-size:0.9rem; margin:12px 0 0 4px;"><%= books.length %> book<%= books.length !== 1 ? 's' : '' %> found</p>

        <!-- Book Grid -->
        <% if(books.length > 0) { %>
            <div class="book-grid" id="bookGrid">
                <%- include('partials/book_cards') %>
            </div>
            <% if(page < totalPages) { %>
                <div style="text-align: center; margin-top: 24px;">
                    <button id="loadMoreBtn" class="btn btn-secondary" data-page="<%= page %>" data-total="<%= totalPages %>" style="padding: 10px 24px;">Load More</button>
                </div>
            <% } %>
        <% } else { %>
            <div class="glass-card" style="text-align:center; padding:50px;">
                <i class="fas fa-book-open" style="font-size:3rem; color:#cbd5e1; margin-bottom:16px; display:block;"></i>
                <h3 style="color:#94a3b8;">No books found</h3>
                <p style="color:#b0bec5;">Try a different search term or category.</p>
            </div>
        <% } %>
    </div>

    <script>
        const loadMoreBtn = document.getElementById('loadMoreBtn');
        if (loadMoreBtn) {
            loadMoreBtn.addEventListener('click', async () => {
                let currentPage = parseInt(loadMoreBtn.getAttribute('data-page'));
                const totalPages = parseInt(loadMoreBtn.getAttribute('data-total'));
                if (currentPage >= totalPages) return;
                
                loadMoreBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Loading...';
                loadMoreBtn.disabled = true;

                const nextPage = currentPage + 1;
                const url = new URL(window.location.href);
                url.searchParams.set('page', nextPage);
                url.searchParams.set('ajax', 'true');

                try {
                    const response = await fetch(url.toString());
                    const html = await response.text();
                    document.getElementById('bookGrid').insertAdjacentHTML('beforeend', html);
                    
                    loadMoreBtn.setAttribute('data-page', nextPage);
                    if (nextPage >= totalPages) {
                        loadMoreBtn.style.display = 'none';
                    } else {
                        loadMoreBtn.innerHTML = 'Load More';
                        loadMoreBtn.disabled = false;
                    }
                } catch (err) {
                    console.error('Error loading more books:', err);
                    loadMoreBtn.innerHTML = 'Error. Try Again';
                    loadMoreBtn.disabled = false;
                }
            });
        }
    </script>
</body>

</html>
