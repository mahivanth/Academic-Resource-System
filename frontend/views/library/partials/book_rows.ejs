<% books.forEach(book => { %>
<tr style="border-top:1px solid #f1f5f9;">
    <td style="padding:14px 18px;">
        <div style="font-weight:600; color:#1e293b;"><%= book.title %></div>
        <div style="font-size:0.82rem; color:#64748b;">by <%= book.author %></div>
        <% if(book.isbn) { %><div style="font-size:0.75rem; color:#94a3b8;">ISBN: <%= book.isbn %></div><% } %>
    </td>
    <td style="padding:14px 18px;">
        <span style="background:#eff6ff; color:#1e40af; padding:2px 10px; border-radius:999px; font-size:0.75rem; font-weight:600;"><%= book.category %></span>
    </td>
    <td style="padding:14px 18px;">
        <style>
            .copy-count[data-out-of-stock="true"] { color: #ef4444; }
            .copy-count[data-out-of-stock="false"] { color: #10b981; }
        </style>
        <span class="copy-count" style="font-weight: 700;" data-out-of-stock="<%= (book.availableCopies || 0) === 0 %>">
            <%= book.availableCopies || 0 %>
        </span>
        <span style="color:#94a3b8; font-size:0.85rem;"> / <%= book.totalCopies %></span>
    </td>
    <td style="padding:14px 18px;">
        <div style="display:flex; gap:8px; align-items:center;">
            <button class="btn btn-secondary edit-btn" style="padding:6px 14px; font-size:0.8rem;"
                data-id="<%= book._id %>"
                data-title="<%= book.title %>"
                data-author="<%= book.author %>"
                data-isbn="<%= book.isbn || '' %>"
                data-category="<%= book.category %>"
                data-copies="<%= book.totalCopies %>"
                data-desc="<%= book.description || '' %>">
                <i class="fas fa-edit"></i> Edit
            </button>
            <form action="/library/books/<%= book._id %>/delete" method="POST" style="margin:0;">
                <button type="submit" class="btn btn-danger" style="padding:6px 14px; font-size:0.8rem;" onclick="return confirm('Are you sure you want to delete this book?')">
                    <i class="fas fa-trash"></i>
                </button>
            </form>
        </div>
    </td>
</tr>
<% }) %>