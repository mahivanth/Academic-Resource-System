<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notifications - ARUS</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/theme.js"></script>
</head>

<body>
    <div class="dashboard-container">
        <%- include('../partials/header') %>

        <h1>My Notifications</h1>

        <div class="actions" style="margin-bottom: 20px; display: flex; gap: 10px;">
            <form action="/notifications/mark-all-read" method="POST">
                <button type="submit" class="btn btn-secondary">Mark All as Read</button>
            </form>
            <form action="/notifications/delete-all" method="POST" onsubmit="return confirm('Are you sure you want to delete all notifications?')">
                <button type="submit" class="btn btn-danger">Delete All Notifications</button>
            </form>
        </div>

        <div class="notifications-list">
            <%- include('../partials/messages') %>

            <% if(notifications && notifications.length > 0) { %>
                <% notifications.forEach(function(notification) { %>
                    <div class="glass-card notif-card <%= notification.read ? 'read' : 'unread' %> type-<%= notification.type || 'info' %>">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div>
                                <p style="margin: 0;">
                                    <%= notification.message %>
                                </p>
                                <small class="text-muted-small">
                                    <%= notification.createdAt.toLocaleString() %>
                                </small>
                            </div>
                            <div style="display: flex; gap: 8px;">
                                <% if(!notification.read) { %>
                                    <form action="/notifications/<%= notification._id %>/read" method="POST">
                                        <button type="submit" class="btn btn-sm btn-primary">Mark as Read</button>
                                    </form>
                                <% } %>
                                <form action="/notifications/<%= notification._id %>/delete" method="POST">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this notification?')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="glass-card" style="padding: 20px; text-align: center;">
                    <p style="margin: 0; color: #666;">No notifications found.</p>
                </div>
            <% } %>
        </div>
    </div>
</body>

</html>