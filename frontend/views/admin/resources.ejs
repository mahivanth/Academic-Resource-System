<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Resources - ARUS</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/theme.js"></script>
</head>

<body>
    <div class="dashboard-container">
        <%- include('../partials/header') %>

            <div class="header-actions" style="display: flex; justify-content: space-between; align-items: center;">
                <h1>
                    <% if(parent) { %>
                        <a href="/admin/resources?parentId=<%= parent.parent %>"><i class="fas fa-arrow-left"></i></a>
                        <%= parent.name %>
                            <% } else { %>
                                Resources
                                <% } %>
                </h1>
                <a href="/admin/resources/create?parentId=<%= parent ? parent._id : '' %>" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Create New
                </a>
            </div>

            <%- include('../partials/messages') %>

                <div class="grid-container"
                    style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px;">
                    <% if(resources.length> 0) { %>
                        <% resources.forEach(function(resource) { %>
                            <div class="glass-card resource-card">
                                <div class="icon" style="font-size: 3rem; text-align: center; margin-bottom: 10px;">
                                    <% if(resource.type==='folder' ) { %>
                                        <a href="/admin/resources?parentId=<%= resource._id %>" style="color: #ffd700;">
                                            <i class="fas fa-folder"></i>
                                        </a>
                                        <% } else { %>
                                            <i class="fas fa-flask" style="color: #00cec9;"></i>
                                            <% } %>
                                </div>
                                <h3 style="text-align: center;">
                                    <%= resource.name %>
                                </h3>

                                <div class="card-actions"
                                    style="display: flex; justify-content: space-between; margin-top: 15px;">
                                    <a href="/admin/resources/<%= resource._id %>/edit"
                                        class="btn btn-sm btn-secondary">Edit</a>
                                    <a href="/admin/resources/<%= resource._id %>/delete" class="btn btn-sm btn-google"
                                        onclick="return confirm('Are you sure?')">Delete</a>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <p>No resources found.</p>
                                    <% } %>
                </div>
    </div>
</body>

</html>