<% students.forEach(function(u) { %>
    <tr style="border-bottom: 1px solid #f1f5f9; transition: background 0.2s;" onmouseover="this.style.background='#fafafa'" onmouseout="this.style.background='white'">
        <td style="padding: 12px 15px; width: 25%; color: #334155; font-size: 0.9rem; text-align: center;"><%= u.name %></td>
        <td style="padding: 12px 15px; width: 35%; color: #64748b; font-size: 0.85rem; word-break: break-word; text-align: center;"><%= u.email %></td>
        <td style="padding: 12px 15px; width: 15%; color: #334155; font-size: 0.9rem; text-align: center;"><%= u.rollNo || '-' %></td>
        <td style="padding: 12px 15px; width: 25%; text-align: center;">
            <div style="display: flex; gap: 6px; justify-content: center; align-items: center; flex-wrap: nowrap;">
                <% if(u._id.toString() !== user._id.toString()) { %>
                    <!-- Block/Unblock Button -->
                    <% if(u.isBlocked) { %>
                        <a href="/admin/users/toggle-block/<%= u._id %>" class="btn btn-warning" style="padding: 5px 10px; font-size: 0.75rem; background-color: #fef3c7; color: #92400e; border: 1px solid #fcd34d; border-radius: 6px; text-decoration: none; display: inline-flex; align-items: center; gap: 4px;" title="Unblock Student">
                            <i class="fas fa-unlock" style="font-size: 0.7rem;"></i> Unblock
                        </a>
                    <% } else { %>
                        <a href="/admin/users/toggle-block/<%= u._id %>" class="btn btn-secondary" style="padding: 5px 10px; font-size: 0.75rem; background-color: #f1f5f9; color: #475569; border: 1px solid #e2e8f0; border-radius: 6px; text-decoration: none; display: inline-flex; align-items: center; gap: 4px;" onclick="return confirm('Are you sure you want to block this student?');" title="Block Student">
                            <i class="fas fa-lock" style="font-size: 0.7rem;"></i> Block
                        </a>
                    <% } %>
                    <a href="/admin/students/<%= u._id %>/edit" class="btn btn-primary" style="padding: 5px 10px; font-size: 0.75rem; background-color: #3b82f6; color: white; border: none; border-radius: 6px; text-decoration: none; display: inline-flex; align-items: center; gap: 4px;" title="Edit Student">
                        <i class="fas fa-edit" style="font-size: 0.7rem;"></i> Edit
                    </a>
                    <a href="/admin/users/delete/<%= u._id %>" class="btn btn-danger" style="padding: 5px 10px; font-size: 0.75rem; background-color: #ef4444; color: white; border: none; border-radius: 6px; text-decoration: none; display: inline-flex; align-items: center; gap: 4px;" onclick="return confirm('Are you sure you want to delete this student?');" title="Delete Student">
                        <i class="fas fa-trash" style="font-size: 0.7rem;"></i> Delete
                    </a>
                <% } else { %>
                    <span style="color: #94a3b8; font-size: 0.8rem; font-style: italic;">Current User</span>
                <% } %>
            </div>
        </td>
    </tr>
<% }); %>
