<% faculty.forEach(function(u) { %>
    <tr style="border-bottom: 1px solid #dee2e6;">
        <td style="padding: 10px;"><%= u.name %></td>
        <td style="padding: 10px;"><%= u.email %></td>
        <td style="padding: 10px;"><%= u.facultyId || '-' %></td>
        <td style="padding: 10px;"><%= u.department || 'Unassigned' %></td>
        <td style="padding: 10px;">
            <% let formattedType = 'Unknown Type';
            if (u.facultyType) {
                if (u.facultyType === 'teaching') formattedType = 'Teaching Faculty';
                else if (u.facultyType === 'non-teaching') formattedType = 'Non-Teaching Faculty';
                else if (u.facultyType === 'intern') formattedType = 'Intern';
            } %>
            <%= formattedType %>
        </td>
        <td style="padding: 10px; display: flex; gap: 5px; white-space: nowrap; justify-content: center;">
            <% if(u._id.toString() !== user._id.toString()) { %>
                <!-- Block/Unblock Button -->
                <% if(u.isBlocked) { %>
                    <a href="/admin/users/toggle-block/<%= u._id %>" class="btn btn-warning" style="padding: 4px 8px; font-size: 0.9em; background-color: #ffc107; color: black; border: none; border-radius: 4px; text-decoration: none; width: 85px; display: inline-flex; align-items: center; justify-content: center; gap: 5px;">
                        <i class="fas fa-unlock"></i> Unblock
                    </a>
                <% } else { %>
                    <a href="/admin/users/toggle-block/<%= u._id %>" class="btn btn-secondary" style="padding: 4px 8px; font-size: 0.9em; background-color: #6c757d; color: white; border: none; border-radius: 4px; text-decoration: none; width: 85px; display: inline-flex; align-items: center; justify-content: center; gap: 5px;" onclick="return confirm('Are you sure you want to block this faculty member?');">
                        <i class="fas fa-lock"></i> Block
                    </a>
                <% } %>
                <a href="/admin/faculty/<%= u._id %>/edit" class="btn btn-primary" style="padding: 4px 8px; font-size: 0.9em; background-color: #0d6efd; color: white; border: none; border-radius: 4px; text-decoration: none; width: 85px; display: inline-flex; align-items: center; justify-content: center; gap: 5px;">
                    <i class="fas fa-edit"></i> Edit
                </a>
                
                <a href="/admin/users/delete/<%= u._id %>" class="btn btn-danger" style="padding: 4px 8px; font-size: 0.9em; background-color: #dc3545; color: white; border: none; border-radius: 4px; text-decoration: none; width: 85px; display: inline-flex; align-items: center; justify-content: center; gap: 5px;" onclick="return confirm('Are you sure you want to delete this faculty member?');">
                    <i class="fas fa-trash"></i> Delete
                </a>
            <% } else { %>
                <span style="color: gray; font-size: 0.9em;">Current User</span>
            <% } %>
        </td>
    </tr>
<% }); %>
