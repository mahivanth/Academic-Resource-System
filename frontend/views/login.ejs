<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - ARUS</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/theme.js"></script>
</head>

<body>
    <div class="login-container">
        <div class="glass-card">
            <h2><i class="fas fa-user-circle"></i> Login</h2>
            <%- include('partials/messages') %>
                <form action="/users/login" method="POST">
                    <div class="form-group">
                        <label for="username">Username, Email, Roll No, or Faculty ID</label>
                        <input type="text" id="username" name="username" required placeholder="Enter your ID or Email">
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="password" required placeholder="Enter your password">
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">Login</button>
                </form>
                <div class="divider">OR</div>
                <a href="/auth/google" class="btn btn-google btn-block">
                    <i class="fab fa-google"></i> Sign in with Google
                </a>
        </div>
    </div>
</body>

</html>